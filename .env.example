# ── Aplicação ─────────────────────────────────────────
NODE_ENV=development
# PORT da API REST
PORT=3333
# URL pública da API (usada para gerar links nos e-mails)
API_URL=http://localhost:3333
# URL pública do frontend (usado para CORS e links nos e-mails)
WEB_URL=http://localhost:5173

# ── Banco de Dados (PostgreSQL) ───────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookme

# ── Redis ─────────────────────────────────────────────
# Usado para: cache de disponibilidade + filas BullMQ
REDIS_URL=redis://localhost:6379

# ── Autenticação JWT ──────────────────────────────────
# Access Token: curto prazo, armazenado em memória no cliente
# Use um segredo forte e diferente para cada um (ex: openssl rand -hex 64)
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-pelo-menos-64-chars
JWT_ACCESS_EXPIRES_IN=15m

# Refresh Token: longo prazo, armazenado em cookie HttpOnly
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-de-pelo-menos-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── E-mail ────────────────────────────────────────────
# Provedor recomendado para dev: Resend (resend.com) — tem plano gratuito
# Para testes locais: Mailhog (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog)
RESEND_API_KEY=re_substitua_pela_sua_chave
EMAIL_FROM="BookMe <noreply@bookme.com.br>"

# ── Observabilidade (OpenTelemetry) ───────────────────
# Nome do serviço nos traces e métricas
OTEL_SERVICE_NAME=bookme-api
# Endpoint do collector OTEL (ex: Grafana Cloud, Jaeger local)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
