.env.*.local
.env.development
.env.test
.env.production

# ── Cobertura de testes ───────────────────────────────
coverage/
.nyc_output/

# ── Cache e temporários ───────────────────────────────
.cache/
tmp/
temp/
*.tmp
*.temp
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Drizzle ORM ───────────────────────────────────────
