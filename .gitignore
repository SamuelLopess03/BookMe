drizzle/meta/_journal.json

# ── TypeScript ────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Editores e IDEs ───────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Sistema operacional ───────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ── Docker ────────────────────────────────────────────
